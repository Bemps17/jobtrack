# Copier vers .env.local (ne pas committer les vraies valeurs)

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mode défaut : service role côté serveur uniquement (RLS contournée ; filtre user_id dans le code).
SUPABASE_SERVICE_ROLE_KEY=

# Si true : client Supabase = clé anon + JWT Clerk ; RLS en base (voir prompts/supabase-user-id-clerk-rls.sql).
# Intégration Clerk ↔ Supabase (dashboard Clerk + provider Clerk dans Supabase Auth).
# SUPABASE_USE_CLERK_JWT=true

# Si défini (ex. supabase), utilise getToken({ template }) au lieu du JWT de session seul.
# CLERK_SUPABASE_JWT_TEMPLATE=supabase
